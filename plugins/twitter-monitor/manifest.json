{
  "name": "twitter-monitor",
  "version": "2.0.0",
  "pluginApiVersion": "1.0.0",
  "description": "抓取、缓存并整理指定 Twitter 账号内容，支持搜索用户、指定数量获取推文、每日自动获取并 AI 总结",
  "author": "Open-AwA Team",
  "permissions": [
    "network:http",
    "file:read",
    "file:write"
  ],
  "auto_authorize_permissions": true,
  "extensions": [
    {
      "point": "tool",
      "name": "fetch_user_tweets",
      "version": "2.0.0",
      "config": {
        "description": "获取指定 Twitter 用户的指定数量推文（用户必须提供推文数量），同时写入缓存"
      }
    },
    {
      "point": "tool",
      "name": "search_twitter_users",
      "version": "2.0.0",
      "config": {
        "description": "按关键词搜索 Twitter 用户"
      }
    },
    {
      "point": "tool",
      "name": "fetch_twitter_tweets",
      "version": "2.0.0",
      "config": {
        "description": "批量抓取一个或多个 Twitter 账号的最新推文并缓存到本地"
      }
    },
    {
      "point": "tool",
      "name": "read_twitter_cache",
      "version": "2.0.0",
      "config": {
        "description": "读取最近一次缓存的推文数据"
      }
    },
    {
      "point": "tool",
      "name": "get_twitter_daily_tweets",
      "version": "2.0.0",
      "config": {
        "description": "读取某一天累积保存的推文数据"
      }
    },
    {
      "point": "tool",
      "name": "get_twitter_stats",
      "version": "2.0.0",
      "config": {
        "description": "查看缓存中的推文统计信息"
      }
    },
    {
      "point": "tool",
      "name": "get_twitter_user_info",
      "version": "2.0.0",
      "config": {
        "description": "查询指定 Twitter 用户的详细账号信息"
      }
    },
    {
      "point": "tool",
      "name": "search_tweets",
      "version": "2.0.0",
      "config": {
        "description": "高级推文搜索，支持 from:user、关键词、时间范围等过滤条件，结果自动缓存"
      }
    },
    {
      "point": "tool",
      "name": "get_tweet_replies",
      "version": "2.0.0",
      "config": {
        "description": "获取指定推文的回复列表"
      }
    },
    {
      "point": "tool",
      "name": "get_user_followers",
      "version": "2.0.0",
      "config": {
        "description": "获取指定 Twitter 用户的粉丝列表"
      }
    },
    {
      "point": "tool",
      "name": "get_user_following",
      "version": "2.0.0",
      "config": {
        "description": "获取指定 Twitter 用户关注的用户列表"
      }
    },
    {
      "point": "tool",
      "name": "summarize_twitter_tweets",
      "version": "2.0.0",
      "config": {
        "description": "整理缓存中的推文和摘要提示，由当前对话模型直接完成总结"
      }
    },
    {
      "point": "tool",
      "name": "trigger_auto_fetch",
      "version": "2.0.0",
      "config": {
        "description": "手动触发一次自动获取：获取插件配置中 monitored_users 的最新推文并自动总结"
      }
    },
    {
      "point": "tool",
      "name": "start_auto_fetch_scheduler",
      "version": "2.0.0",
      "config": {
        "description": "启动后台自动获取调度器，按配置的间隔定时获取推文"
      }
    },
    {
      "point": "tool",
      "name": "stop_auto_fetch_scheduler",
      "version": "2.0.0",
      "config": {
        "description": "停止后台自动获取调度器"
      }
    },
    {
      "point": "tool",
      "name": "get_scheduler_status",
      "version": "2.0.0",
      "config": {
        "description": "查看自动获取调度器的运行状态和配置"
      }
    }
  ]
}
