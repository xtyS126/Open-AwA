# 开发环境配置
# 此文件可提交到版本库，仅包含非敏感的开发默认值。
# 如需覆盖敏感配置（如真实测试凭据），请创建 .env.development.local（已加入 .gitignore）。

# 是否在开发模式下启用自动登录（默认关闭，避免误开）
# 设为 true 后，应用启动时会自动使用下方测试凭据注册并登录
VITE_ENABLE_DEV_AUTO_LOGIN=true

# 开发模式自动登录使用的测试账户
# 修改为真实测试凭据时，请在 .env.development.local 中覆盖，而非直接修改此文件
VITE_TEST_USERNAME=test_user_default
VITE_TEST_PASSWORD=test_password_123

