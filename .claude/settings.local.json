      "Bash(rm -rf .)",
      "Bash(dd *)",
      "Bash(:(){ :|& };:)",
      "Bash(wget *)",
      "Bash(curl *)",
      "Bash(reg delete *)",
      "Bash(reg add HKLM *)",
      "Bash(shutdown *)",
      "Bash(Stop-Computer *)",
      "Bash(Remove-Item *)",
      "Bash(Format-Volume *)",
      "Bash(Clear-Content *)",
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/secrets/**)",
      "Read(//**/id_rsa*)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Edit(//**/.env)",
      "Edit(//**/.env.*)",
      "Edit(//**/secrets/**)",
      "Edit(//d/代码/Open-AwA/.git/**)",
      "Edit(//d/代码/Open-AwA/.claude/settings.local.json)"
