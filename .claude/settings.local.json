  "env": {
    "LOG_LEVEL": "info",
    "PYTHONPATH": "${workspaceFolder}/backend",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "1"
